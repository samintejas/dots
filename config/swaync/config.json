{
  "positionX": "right",
  "positionY": "bottom",
  "layer": "overlay",
  "control-center-margin-top": 0,
  "control-center-margin-bottom": 0,
  "control-center-margin-right": 0,
  "control-center-margin-left": 0,
  "notification-margin": 2,
  "notification-padding": 15,
  "notification-icon-size": 32,
  "notification-window-width": 400,
  "timeout": 15,
  "timeout-low": 3,
  "timeout-critical": 10,
  "hide-on-clear": true,
  "hide-on-action": true,
  "image-visibility": "when-available",
  "widgets": [
    "title",
    "dnd",
    "mpris",
    "calendar",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": false
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "image-size": 56,
      "image-radius": 0
    },
    "calendar": {
      "mode": "month",
      "show-week-numbers": false,
      "start-on-monday": true,
      "format": {
        "today": "<b><u>{}</u></b>"
      }
    },
    "notifications": {
      "show-count": true
    }
  }
}
