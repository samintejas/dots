[user]
	email = samintejas@gmail.com
	name = samintejas

[init]
	defaultBranch = main

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	dark = true
	line-numbers = true
	side-by-side = false

[merge]
	conflictStyle = zdiff3

[pull]
	rebase = false

[push]
	default = simple

[fetch]
	prune = true
